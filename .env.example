# Never commit a real key. Create .env.local locally or set these in Vercel.

# DeepSeek 负责面向用户的咨询式回应（流式）
DEEPSEEK_API_KEY=your-rotated-production-key
# Model for the summary route + chat fallback only. The chat deep/fast tiers are
# chosen by session pace (v4-pro / v4-flash) regardless of this value.
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi (Moonshot) 负责后台的"督导/个案概念化"长上下文规划。
# 没有 KIMI_API_KEY 时系统会退化为单模型模式，但失去专业差异化。
KIMI_API_KEY=your-rotated-moonshot-key
KIMI_MODEL=moonshot-v1-32k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ---------------------------------------------------------------------------
# Embeddings / vector RAG (P4 流①). Optional: if unset, knowledge retrieval
# falls back to keyword matching — the app still works, just without semantic
# recall. After changing these (or the cards), re-run `npm run kb:embed`.
#
# PRIVACY:
#   - cloud mode: the user's QUERY TEXT is sent to the embedding service
#     (e.g. OpenAI) to be vectorized. Card text is embedded at build time.
#   - local mode: query text is sent only to YOUR OWN sidecar (EMBEDDING_BASE_URL)
#     and never leaves your infrastructure.
# ---------------------------------------------------------------------------

# cloud | local  (default: cloud)
EMBEDDING_PROVIDER=cloud
# cloud: OpenAI-compatible base, POST {BASE}/embeddings (default https://api.openai.com/v1)
# local: full URL of your on-prem embedder, POST {BASE} with { input: string[] }
EMBEDDING_BASE_URL=https://api.openai.com/v1
# cloud only — bearer key. Without it, cloud mode is treated as unconfigured
# (→ keyword fallback). Never commit a real key.
EMBEDDING_API_KEY=your-embedding-api-key
# cloud default: text-embedding-3-small ; local default: bge-m3
EMBEDDING_MODEL=text-embedding-3-small
# Requested output dimension. 0 / unset = provider default (must match the dim
# baked into knowledge-embeddings.generated.json).
EMBEDDING_DIM=0
# Minimum cosine similarity for a card to be retrieved (0..1, default 0.30).
RAG_MIN_SCORE=0.30
