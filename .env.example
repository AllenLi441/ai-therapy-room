# Never commit a real key. Create .env.local locally or set these in Vercel.

# DeepSeek 负责面向用户的咨询式回应（流式）
DEEPSEEK_API_KEY=your-rotated-production-key
# Model for the summary route + chat fallback only. The chat deep/fast tiers are
# chosen by session pace (v4-pro / v4-flash) regardless of this value.
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi (Moonshot) 是隐性自杀风险 LLM 判官的首选模型(implicit-risk.ts)。
# ⚠️ 安全关键:绝对不要删除 KIMI_API_KEY —— 没有它 isKimiConfigured() 为 false,
#   判官整个被跳过(DeepSeek 兜底只在 Kimi 调用失败后可达),隐性风险检测会
#   静默退化成纯词表。哪怕账户欠费也要留着这把 key:失败会触发熔断并由
#   DeepSeek 兜底判官接管(2026-07 实测该形态稳定,判官质量不降反升);
#   给 Moonshot 充值后熔断窗口(10 分钟)一过自动恢复 Kimi,零操作。
KIMI_API_KEY=your-rotated-moonshot-key
KIMI_MODEL=moonshot-v1-32k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ---------------------------------------------------------------------------
# Embeddings / vector RAG (P4 流①). Optional: if unset, knowledge retrieval
# falls back to keyword matching — the app still works, just without semantic
# recall. After changing these (or the cards), re-run `npm run kb:embed`.
#
# PRIVACY:
#   - cloud mode: the user's QUERY TEXT is sent to the embedding service
#     (e.g. OpenAI) to be vectorized. Card text is embedded at build time.
#   - local mode: query text is sent only to YOUR OWN sidecar (EMBEDDING_BASE_URL)
#     and never leaves your infrastructure.
# ---------------------------------------------------------------------------

# cloud | local  (default: cloud)
EMBEDDING_PROVIDER=cloud
#
# ── FREE semantic-search options (pick ONE; all OpenAI-compatible → zero code change) ──
# Turning the KB search from keyword → real vector semantics costs $0. After setting a
# key: run `npm run kb:embed` ONCE to bake card vectors into
# knowledge-embeddings.generated.json, AND set the SAME key in Vercel so the runtime can
# embed each user query. With no key the app still does REAL KB search, just lexical
# (keyword) instead of semantic — it is never "the LLM making things up".
#
# OPTION 1 — SiliconFlow (硅基流动) ← ACTIVE: the committed vectors were baked with THIS.
#   knowledge-embeddings.generated.json was built on the .COM (international) platform with
#   Qwen/Qwen3-Embedding-0.6B (1024-dim, top multilingual MTEB). The RUNTIME MUST use the SAME
#   base+model or it silently falls back to keyword. Key from cloud.siliconflow.com → API 密钥.
EMBEDDING_BASE_URL=https://api.siliconflow.com/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=0
EMBEDDING_API_KEY=your-siliconflow-com-key
#   (China .cn platform instead? base https://api.siliconflow.cn/v1 + model BAAI/bge-m3,
#    then re-run `npm run kb:embed` so the baked vectors match that provider.)
#
# OPTION 2 — Cloudflare Workers AI bge-m3   (FREE: 10,000 req/day, no credit card)
#   EMBEDDING_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1
#   EMBEDDING_MODEL=@cf/baai/bge-m3   EMBEDDING_DIM=0   EMBEDDING_API_KEY=<CF API token>
#
# OPTION 3 — Google Gemini   (FREE: ~1500 req/day, no credit card; query text → Google)
#   EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   EMBEDDING_MODEL=text-embedding-004   EMBEDDING_DIM=0   key from aistudio.google.com
#
# bge-m3 is fixed at 1024 dims — keep EMBEDDING_DIM=0 so we don't send a `dimensions`
# field the model would reject; the runtime match check accepts the baked dim.
#
# PRIVACY: every cloud option sends the user's QUERY TEXT to the provider to vectorize
# (card text is embedded once at build time). If query-text privacy matters more than
# zero-setup, run a self-hosted embedder via EMBEDDING_PROVIDER=local (text never leaves
# your box) — see the local block logic in src/lib/embeddings.ts.
#
# Minimum cosine similarity for a card to be retrieved (0..1, default 0.50). Higher =
# only strongly-relevant cards ground the reply (casual venting stays card-free & warm);
# lower = more recall but risks a textbook tone. With Qwen3/bge vectors, 0.50 cleanly
# separates real topical matches (0.55–0.69) from same-domain noise (0.35–0.47).
# NOTE: this cosine threshold is only the FALLBACK now — when a reranker is available the
# real precision gate is RERANK_MIN_SCORE below; cosine just does broad recall.
RAG_MIN_SCORE=0.50

# RERANK (the "检索完先整理" step). Cosine baselines run high in-domain (a relationship-
# conflict message scores ~0.36 against EVERY card), so after broad vector recall a cross-
# encoder reranker re-judges TRUE relevance — irrelevant cards score ~0.00, an on-topic
# card ~0.99 — and only those above RERANK_MIN_SCORE are kept (& shown). This is what keeps
# the displayed sources matching the reply. Reuses EMBEDDING_BASE_URL + EMBEDDING_API_KEY
# (same SiliconFlow account). Unset / failure → falls back to the cosine threshold above.
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
# Minimum reranker relevance (0..1) to keep a card. 0.3 keeps strong matches, drops noise.
RERANK_MIN_SCORE=0.3
# Per-rerank timeout (ms) — tight so it never blows the fast-mode reply budget.
RERANK_TIMEOUT_MS=3500

# ---------------------------------------------------------------------------
# Qdrant Cloud vector store (P5 RAG · Tier-1). Optional: if unset, retrieval
# falls through to the committed-vector path and then keyword matching (fail-safe). The
# corpus is built offline by `node scripts/ingest/upsert-cards.mjs`; the runtime only
# READS Qdrant. Query + corpus vectors MUST come from the SAME embedding model.
#
# ⚠️ Do NOT repoint EMBEDDING_BASE_URL / EMBEDDING_MODEL to a different provider to "fix"
#    Qdrant — rerank.ts reuses EMBEDDING_BASE_URL, and a model switch silently breaks
#    cosine against both the baked card vectors AND the Qdrant collection. Keep them stable;
#    re-run the ingest script if the model ever legitimately changes.
# ---------------------------------------------------------------------------
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-cloud-api-key
QDRANT_COLLECTION=jingshi-kb

# ---------------------------------------------------------------------------
# Live web-search FALLBACK (optional). When the curated KB has NO relevant card AND the
# user is in DEEP mode on a non-crisis turn, the app searches AUTHORITATIVE medical/
# research domains live (who.int / nih.gov / nhs.uk / apa.org / cdc.gov / pubmed /
# cochrane / mayoclinic …) and grounds the reply in what it finds — sources shown to the
# user, tagged "实时". No key → disabled (KB-only). Crisis turns are NEVER web-searched.
#
# RECOMMENDED: Tavily — FREE 1,000 searches/month, no credit card. Key at tavily.com.
# ---------------------------------------------------------------------------
SEARCH_API_KEY=your-free-tavily-key
# Provider base (Tavily default). Must accept POST {base}/search with
# { query, include_domains, max_results } → { results: [{ title, url, content }] }.
SEARCH_BASE_URL=https://api.tavily.com
# Per-search timeout (ms). Tight so a slow search never stalls the deep reply.
SEARCH_TIMEOUT_MS=6000
