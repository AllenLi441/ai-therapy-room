# dependencies
/node_modules

# next.js
/.next/
/out/
/build

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# env files — NEVER commit real keys (.env.example is the only one tracked)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# recovery scratch (reference only, not part of the app)
_recovered_frontend_reference/

# CI workflow needs the gh "workflow" token scope to push.
# Re-enable later with: gh auth refresh -s workflow  (then un-ignore + git add)
/.github/workflows/

# design handoff (prototype) — integrated into src/, kept locally as reference
/design_handoff_jingshi/

# safety-test ratchet: commit the baseline, not the raw vitest report
/safety-ci/_raw.json
scripts/ingest/.cache/

# eval suite: generated outputs + runtime workdir
/eval/reports/*
!/eval/reports/.gitkeep
!/eval/reports/referee_gold_v1.audit.json
/eval/.workdir/

# decision logs may contain raw user content (QUIET_ROOM_DECISION_LOG_RAW) — never commit
/logs/

# local working notes / private scratch — never publish
_BATCH_PROMPT*
_PLAN_*
_RAG搭建*
_SAFETY_v2_*
_SAFETY_REARCH*
_DEPLOY_LINE_PATCHES/
jingshi-eval/
.omc/
logs/
eval/.workdir/
# Human-study operational records are local/private until ethics and publication review.
eval/human-study/annotator_*.csv
eval/human-study/human_gold.jsonl
eval/human-study/human_gold.audit.json
eval/human-study/HUMAN_GOLD_REPORT.md
eval/human-study/CALIBRATION_REPORT.md
eval/human-study/adjudication_*.csv
eval/human-study/RECRUITMENT_LOG.csv
eval/human-study/signed-consent/
# Hidden scoring key must remain local or blinding is broken.
eval/human-study/sheets/KEY_mapping_*.jsonl
# Blind annotation sheets can contain licensed or sensitive source text.
eval/human-study/sheets/*.csv
# Dataset-expansion author/reviewer operational files stay local until explicit review.
eval/dataset-expansion/KEY_mapping_*.jsonl
eval/dataset-expansion/annotator_*.csv
eval/dataset-expansion/private/
